{
  "name": "travel-capsule-ai",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "pages:build": "cd apps/web && npm install && npm run build && npx @cloudflare/next-on-pages@1",
    "deploy:worker": "cd apps/worker && wrangler deploy",
    "deploy:web": "cd apps/web && npm run deploy"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
